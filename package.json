{
  "name": "re-wild",
  "version": "0.0.2",
  "description": "Game about exploring earth's history",
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "test": "npm run unit-tests && npm run test --workspaces --if-present",
    "unit-tests": "jest",
    "clean": "rimraf public",
    "build": "npm run clean && node ./esbuild.js && npm run ts-check",
    "ts-check": "tsc --noEmit --project src/tsconfig.json",
    "ts-check-watch": "tsc --noEmit --watch --project src/tsconfig.json",
    "watch": "node ./esbuild.js --watch",
    "start": "npm-run-all --parallel server watch ts-check-watch",
    "server": "live-server --port=9001 --entry-file=index.html --open=/ ./public"
  },
  "repository": {
    "type": "git",
    "url": "git+ssh://git@bitbucket.org/MathewKHenson/rewild-web.git"
  },
  "author": "Mathew Henson",
  "license": "ISC",
  "homepage": "https://bitbucket.org/MathewKHenson/rewild-web#readme",
  "dependencies": {
    "@dimforge/rapier3d-compat": "^0.19.3",
    "date-fns": "2.29.3",
    "firebase": "^9.10.0",
    "firebaseui": "^6.0.1"
  },
  "devDependencies": {
    "@loaders.gl/core": "4.3.4",
    "@loaders.gl/gltf": "4.3.4",
    "@types/jest": "^29.5.0",
    "@types/node": "24.9.1",
    "@webgpu/types": "0.1.21",
    "esbuild": "0.17.18",
    "esbuild-plugin-copy": "^2.1.1",
    "jest": "^29.5.0",
    "jest-environment-jsdom": "^29.5.0",
    "live-server": "1.2.2",
    "npm-run-all": "4.1.5",
    "prettier": "2.3.2",
    "rimraf": "3.0.2",
    "ts-node": "10.9.2",
    "typescript": "5.9.3"
  },
  "workspaces": [
    "packages/rewild-ui",
    "packages/rewild-routing",
    "packages/rewild-common",
    "packages/rewild-renderer"
  ]
}
