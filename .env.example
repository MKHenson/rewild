# Shared asset storage (Scaleway Object Storage, S3-compatible)
# SHARED_ASSETS_BASE_URL is baked in at build time by esbuild.
# For local dev this defaults to http://localhost:9001/assets/shared — no need to set it.
# For production builds, set it to the public Scaleway bucket URL before running npm run build.
SHARED_ASSETS_BASE_URL=https://rewild-shared.s3.<region>.scw.cloud/

# Required only for npm run assets:pull and npm run assets:push.
# The running app never needs these — it only reads public URLs.
SHARED_S3_ENDPOINT=https://s3.<region>.scw.cloud
SHARED_BUCKET_NAME=rewild-shared
SHARED_S3_ACCESS_KEY=<your-scaleway-access-key>
SHARED_S3_SECRET_KEY=<your-scaleway-secret-key>
